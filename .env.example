# Polymarket Trading Bot Configuration
# Copy this to .env and fill in your values

# Your Ethereum private key (from MetaMask or other wallet)
# Must have USDC on Polygon network
PRIVATE_KEY=your_private_key_here

# Your wallet address (the address that holds USDC on Polygon)
WALLET_ADDRESS=your_wallet_address_here

# Signature type: 0=EOA (MetaMask), 1=Email/Magic wallet, 2=Browser proxy
SIGNATURE_TYPE=0

# Optional: Funder/proxy address (required for email/smart contract wallets)
# FUNDER_ADDRESS=your_funder_address_here

# Trading parameters
BANKROLL=99.0
MAX_POSITION_PCT=0.25
MIN_EDGE=0.05
KELLY_FRACTION=0.25
MAX_CONCURRENT_POSITIONS=5
DRY_RUN=true
